    {
      "name": "Incident Creation",
      "item": [
        {
          "name": "Create Incident Card",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json(); // Parse the response body as JSON   ",
                  "",
                  "pm.environment.set(\"card_id_open\", response.id);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "https://api.trello.com/1/cards?idList={{list_id_open}}&name={{incident_name}}&desc={{incident_description}}&key={{api_key}}&token={{api_token}}",
              "protocol": "https",
              "host": [
                "api",
                "trello",
                "com"
              ],
              "path": [
                "1",
                "cards"
              ],
              "query": [
                {
                  "key": "idList",
                  "value": "{{list_id_open}}"
                },
                {
                  "key": "name",
                  "value": "{{incident_name}}"
                },
                {
                  "key": "desc",
                  "value": "{{incident_description}}"
                },
                {
                  "key": "key",
                  "value": "{{api_key}}"
                },
                {
                  "key": "token",
                  "value": "{{api_token}}"
                }
              ]
            },
            "description": "# Create Incident\n\n## Purpose\n\nCreates a new incident card in the Open Incidents workflow list.\n\n## Method\n\nPOST\n\n## Variables Used\n\n- list_id_open\n    \n- incident_name\n    \n- incident_description\n    \n- api_key\n    \n- api_token\n    \n\n## Expected Result\n\n- Incident card created successfully\n    \n- card_id saved automatically\n    \n- Status code 200 returned\n    \n\n## Automation\n\nUses Post-response scripts to save generated card ID into environment variables."
          },
          "response": []
        }
      ]
    },
